# Gemini API key used SERVER-SIDE ONLY to analyze uploaded drawings.
# Get a free key at https://aistudio.google.com (no credit card required).
# The frontend never asks for or sends a key — the backend does all
# image analysis using this value. If left unset, the backend falls
# back to clearly-labelled mock data automatically.
GEMINI_API_KEY=

# Port the backend listens on (optional, defaults to 3000)
PORT=3000
